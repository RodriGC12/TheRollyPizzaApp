# Copiar este archivo a .env y llenar con tus datos

# Para Supabase, es más fácil usar DATABASE_URL directamente:
# DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

# O puedes usar variables individuales:
#DB_HOST=localhost
#DB_USER=tu_usuario
#DB_PASSWORD=tu_password
#DB_NAME=nombre_db
#DB_PORT=5432
#JWT_SECRET=tu_secreto
#PORT=3000